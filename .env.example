# Connection string do banco Neon (pooled, usada pela aplicação)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Connection string sem pooling. Não é consumida pelo código hoje (migrations
# também usam DATABASE_URL), mas a integração Neon<->Vercel sempre injeta essa
# variável — documentada aqui para o caso de algum driver futuro precisar dela.
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

# Auth.js (NextAuth v5) — obrigatória em produção. Gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="troque-por-um-valor-aleatorio"

# Necessário quando a app roda atrás de proxy/host que o Auth.js não
# reconhece automaticamente (ex: alguns ambientes de preview).
AUTH_TRUST_HOST=true
