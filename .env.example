# Connection string do banco Neon (pooled, usada pela aplicação)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Connection string sem pooling. Não é consumida pelo código hoje (migrations
# também usam DATABASE_URL), mas a integração Neon<->Vercel sempre injeta essa
# variável — documentada aqui para o caso de algum driver futuro precisar dela.
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

# Auth.js (NextAuth v5) — obrigatória em produção. Gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="troque-por-um-valor-aleatorio"

# Necessário quando a app roda atrás de proxy/host que o Auth.js não
# reconhece automaticamente (ex: alguns ambientes de preview).
AUTH_TRUST_HOST=true

# Chave usada para criptografar zapi_token/zapi_client_token antes de
# gravar em whatsapp_channels. Gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIALS_ENCRYPTION_KEY="troque-por-um-valor-aleatorio-base64-32-bytes"

# Cloudflare R2 (S3-compatible) — armazena mídia recebida via WhatsApp.
# Bucket com lifecycle rule: objetos em "media/" (imagem/vídeo/documento)
# expiram em 120 dias; objetos em "audio/" não expiram.
R2_BUCKET="nome-do-bucket"
R2_ACCESS_KEY_ID="access-key-id-do-token-r2"
R2_SECRET_ACCESS_KEY="secret-access-key-do-token-r2"
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"

# Protege /api/cron/cleanup-media (chamado pelo Vercel Cron, ver vercel.json)
# contra chamadas externas. Gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="troque-por-um-valor-aleatorio"
